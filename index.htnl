<!DOCTYPE html>

<html lang="en">

<head>

  <meta charset="UTF-8">

  <title>For You ❤️</title>

  <style>

    body {

      text-align: center;

      font-family: Arial, sans-serif;

      background: linear-gradient(135deg, #ffe6eb, #fff5f7);

      margin-top: 100px;

    }

    h1 {

      font-size: 34px;

    }

    h2 {

      font-weight: normal;

    }

    button {

      font-size: 20px;

      padding: 12px 25px;

      margin: 10px;

      cursor: pointer;

      border-radius: 20px;

      border: none;

      transition: 0.2s;

    }

    #yes {

      background-color: #ff4d6d;

      color: white;

    }

    #no {

      background-color: #ccc;

      position: absolute;

    }

  </style>

</head>

<body>


  <h2>Hi…</h2>

  <h1>Happy Birthday ❤️</h1>


  <h2>Hindi ako magaling sa words…</h2>

  <h2>pero gusto ko lang sabihin ‘to sayo.</h2>


  <br>


  <h2>Nakikita ko lahat.</h2>

  <h2>Yung pagod mo… kahit hindi mo sinasabi.</h2>

  <h2>Yung effort mo… kahit walang nakakakita.</h2>


  <br>


  <h2>Lalo na kay Yuna.</h2>

  <h2>Ang galing mo maging mommy… sobra.</h2>


  <h2>Hindi ko man nasasabi palagi…</h2>

  <h2>pero sobrang proud ako sayo.</h2>


  <br>


  <h2>Hindi madali lahat ngayon…</h2>

  <h2>pero gusto ko lang malaman mo na</h2>


  <h1>kasama mo ko. Lagi. ❤️</h1>


  <br>


  <h2>Kaya ngayong birthday mo…</h2>

  <h2>gusto kitang bawiin kahit saglit. 🥹 </h2>


  <h1>Will you go out on a date with me?</h1>

  <h2>tayo lang… pahinga muna sa lahat 😌</h2>


  <button id="yes" onclick="yesClicked()">Yes ❤️</button>

  <button id="no" onmouseover="moveNo()">No 😅</button>


  <script>

    let noMessages = [

      "Sure ka? 😅",

      "Pag-isipan mo muna…",

      "Kahit saglit lang 😌",

      "Libre ko na…",

      "Please…",

      "Bawi lang ako sayo",

      "Deserve mo to ❤️"

    ];


    let size = 20;


    function moveNo() {

      const noBtn = document.getElementById("no");


      noBtn.innerText = noMessages[Math.floor(Math.random() * noMessages.length)];


      let x = Math.random() * window.innerWidth * 0.6;

      let y = Math.random() * window.innerHeight * 0.6;


      noBtn.style.left = x + "px";

      noBtn.style.top = y + "px";


      const yesBtn = document.getElementById("yes");

      size += 6;

      yesBtn.style.fontSize = size + "px";

    }


    function yesClicked() {

      window.location.href = "yes.html";

    }

  </script>


</body>

</html>

